    classDef red fill:#fef2f2,stroke:#dc2626,stroke-width:2px,color:#0f172a
    classDef purple fill:#faf5ff,stroke:#9333ea,stroke-width:2px,color:#0f172a

    class A,B,C,HF,API,Episode blue
    class Visible,Tools,Sim,Training green
    class Reward,SafetyGate,IntegrityGate orange
    class Hidden,Defects,Truth,Weather,Obstacles,Requirements red
    class Scenarios,Submission,Flow purple
